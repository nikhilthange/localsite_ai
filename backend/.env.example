# ============================================
# LocalSite AI - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.
#
# REQUIRED  = Must be set for any environment
# OPTIONAL  = Can be left blank; feature auto-disables
# GENERATED = Secure defaults provided for dev
# ============================================

# ── Development Configuration ────────────────
# DISABLE_CSRF=true               # Skip CSRF validation (dev only)
# SKIP_EMAIL_VERIFICATION=true    # Allow login without email verification (dev only)
# REDIS_OPTIONAL=true             # Gracefully disable cache/queue when Redis is unavailable (dev only)

# ── Server ────────────────────────────────────
NODE_ENV=development              # development | production | test
PORT=5000                         # API server port

# ── MongoDB ───────────────────────────────────
# REQUIRED. Local dev (Docker): mongodb://admin:password@localhost:27017/localsite_ai?authSource=admin
# Atlas: mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/localsite_ai?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/localsite_ai

# ── Redis ─────────────────────────────────────
# OPTIONAL in development (set REDIS_OPTIONAL=true). Docker Compose provides redis://localhost:6379
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=localsite:

# ── JWT Authentication ───────────────────────
# GENERATED - Replace with strong random values in production
JWT_ACCESS_SECRET=dev-jwt-access-secret-localsite-ai-2024
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-localsite-ai-2024
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Auth Secrets ──────────────────────────────
# GENERATED - Replace with strong random values in production
COOKIE_SECRET=dev-cookie-secret-localsite-ai
CSRF_SECRET=dev-csrf-secret-localsite-ai

# ── Client ────────────────────────────────────
CLIENT_URL=http://localhost:3000   # Frontend URL
APP_URL=http://localhost:5000      # Backend API URL
APP_NAME=LocalSite AI

# ── NVIDIA NIM (AI Engine) ───────────────────
# OPTIONAL - AI features disabled without key
# Get key at https://build.nvidia.com/
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_MAX_TOKENS=2000
NVIDIA_TEMPERATURE=0.7

# ── Email (SendGrid) ─────────────────────────
# OPTIONAL - Email features disabled without key
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
EMAIL_FROM=noreply@localsiteai.com
EMAIL_FROM_NAME=LocalSite AI

# ── SMTP (Fallback email) ────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=

# ── Stripe ────────────────────────────────────
# OPTIONAL - Payment module auto-disabled without keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ── Razorpay ──────────────────────────────────
# OPTIONAL - Payment module auto-disabled without keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── AWS S3 ────────────────────────────────────
# OPTIONAL - File uploads disabled without keys
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ── Cloudflare ────────────────────────────────
# OPTIONAL - CDN/deployment integration disabled without keys
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DOMAIN=
CLOUDFLARE_R2_BUCKET=

# ── Google OAuth ──────────────────────────────
# OPTIONAL - Google login disabled without keys
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
GOOGLE_MAPS_API_KEY=

# ── App Settings ─────────────────────────────
SUPPORT_EMAIL=support@localsiteai.com

# ── MongoDB Pool ─────────────────────────────
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=2
